{
  "name": "elysia-loom",
  "version": "0.2.0-alpha.0",
  "bin": {
    "elysia-loom": "./dist/installer.js",
    "create-loom": "./dist/installer.js",
    "loom-install": "./dist/installer.js"
  },
  "files": [
    "dist",
    "templates/default"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ruwanego/elysia-loom.git"
  },
  "bugs": {
    "url": "https://github.com/ruwanego/elysia-loom/issues"
  },
  "homepage": "https://github.com/ruwanego/elysia-loom#readme",
  "scripts": {
    "build": "bun build src/installer.ts --outfile dist/installer.js --target bun && bun build src/loom.ts --outfile dist/loom.js --target bun --minify",
    "check": "bun run build && bun test && bun pm pack --dry-run",
    "pack:check": "bun pm pack --dry-run",
    "prepack": "bun run build",
    "test": "bun test",
    "loom": "bun run src/loom.ts",
    "loom:install": "bun run src/installer.ts",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "bun-types": "latest",
    "elysia": "latest"
  },
  "module": "dist/loom.js"
}
