{
  "name": "elysia-loom",
  "version": "0.2.0-alpha.0",
  "bin": {
    "elysia-loom": "./src/installer.ts",
    "create-loom": "./src/installer.ts",
    "loom-install": "./src/installer.ts"
  },
  "files": [
    "src",
    "dist/loom.js",
    "templates/default"
  ],
  "scripts": {
    "build": "bun build src/loom.ts --outfile dist/loom.js --target bun --minify",
    "check": "bun run build && bun test && bun pm pack --dry-run",
    "pack:check": "bun pm pack --dry-run",
    "test": "bun test",
    "loom": "bun run src/loom.ts",
    "loom:install": "bun run src/installer.ts",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "bun-types": "latest",
    "elysia": "latest"
  },
  "module": "src/loom.ts"
}
