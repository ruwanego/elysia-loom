{
  "name": "elysia-loom",
  "version": "0.2.0-alpha.0",
  "bin": {
    "elysia-loom": "./scripts/install-loom.ts",
    "create-loom": "./scripts/install-loom.ts",
    "loom-install": "./scripts/install-loom.ts"
  },
  "files": [
    "scripts/install-loom.ts",
    "scripts/loom.ts",
    "templates/default"
  ],
  "scripts": {
    "check": "bun test && bun pm pack --dry-run",
    "pack:check": "bun pm pack --dry-run",
    "test": "bun test",
    "loom": "bun run scripts/loom.ts",
    "loom:install": "bun run scripts/install-loom.ts",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "bun-types": "latest",
    "elysia": "latest"
  },
  "module": "scripts/loom.ts"
}
